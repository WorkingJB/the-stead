{
  "name": "the-stead",
  "version": "0.1.0",
  "private": true,
  "description": "The Stead — installable, offline-first PWA for the fitness pillar training programs.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "start": "npm run start --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web",
    "typecheck": "npm run typecheck --workspace=apps/web",
    "test:e2e": "npm run test:e2e --workspace=apps/web",
    "content:build": "npm run build --workspace=packages/content-pipeline",
    "content:test": "npm run test --workspace=packages/content-pipeline"
  }
}
